# Cross-cutting ignore rules. End-specific (backend / mobile) rules live in
# their own .gitignore: see /backend/.gitignore and /mobile/.gitignore.

# === IDE ===
.idea/
.vscode/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db
*.pem

# === Environment ===
# Root .env (实际部署/开发共用),由用户自己管理; 局部覆盖在各自端内处理
.env
.env.local
.env.*.local

# === Claude Code ===
.claude/

# === PostgreSQL data (mounted volume at repo root) ===
pgdata/

# === Docker ===
.dockerignore
