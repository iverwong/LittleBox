# === Backend ===
LB_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/littlebox
LB_REDIS_URL=redis://redis:6379/0
LB_DEBUG=true
# === LLM Provider API Keys (M6 Step 2.5;其余 LLM 拓扑入 app/core/llm_topology.py) ===
# DeepSeek (primary)
LB_DEEPSEEK_API_KEY=
# Aliyun Bailian OpenAI-compatible (fallback)
LB_BAILIAN_API_KEY=

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=littlebox

# === pgAdmin ===
PGADMIN_EMAIL=admin@littlebox.dev
PGADMIN_PASSWORD=admin

# === Docker Compose ===
COMPOSE_PROJECT_NAME=littlebox

# === LangSmith 生产环境不进行tracing ===
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com
# LANGSMITH_API_KEY=<your-api-key>
# LANGSMITH_PROJECT="littlebox"

