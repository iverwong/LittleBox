# === Backend ===
LB_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/littlebox
LB_REDIS_URL=redis://redis:6379/0
LB_DEBUG=true
# === LLM Providers (M6 Step 2.5) ===
# DeepSeek (primary)
LB_DEEPSEEK_API_KEY=
LB_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LB_DEEPSEEK_MODEL=deepseek-chat
# Aliyun Bailian OpenAI-compatible (fallback)
LB_BAILIAN_API_KEY=
LB_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LB_BAILIAN_MODEL=qwen-plus
LB_LLM_REQUEST_TIMEOUT_SECONDS=60.0

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=littlebox

# === pgAdmin ===
PGADMIN_EMAIL=admin@littlebox.dev
PGADMIN_PASSWORD=admin
